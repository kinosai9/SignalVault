# SignalVault 多源投资研究助手 - .env.example
# 复制为 .env 并填入实际值，.env 不提交 Git
#
# 面向：开发者、高级用户和部署覆盖。
# 普通桌面用户请通过 Web Console → 系统与集成页面完成配置，
# 不需要编辑本文件。

# ── 应用数据根目录（C1-A 新增）────────────────────────────────────
# 设置后所有运行数据（config/data/logs/cache/…）收敛到该目录。
# 不设置则使用平台默认路径：
#   Windows: %APPDATA%/SignalVault
#   macOS:   ~/Library/Application Support/SignalVault
#   Linux:   ~/.local/share/signalvault
# SIGNALVAULT_HOME=

# ── 旧路径覆盖（兼容，优先级低于 SIGNALVAULT_HOME）───────────────
# DATA_DIR=data
# LOG_DIR=logs
# DB_PATH=data/signalvault.db

# ── LLM 配置 ───────────────────────────────────────────────────────
# 普通桌面用户推荐通过「系统与集成 → AI 服务」页面配置，无需编辑此文件。
LLM_PROVIDER=mock
LLM_MODEL=mock-v1
LLM_BASE_URL=
LLM_API_KEY=

# ── Obsidian Vault ──────────────────────────────────────────────────
# 普通桌面用户推荐通过「系统与集成 → Obsidian」页面配置。
# OBSIDIAN_VAULT_PATH=
# OBSIDIAN_EXPORT_ENABLED=false

# ── 日志级别 ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
